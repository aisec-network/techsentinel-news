---
import { siteConfig } from "@config/site";
const nav = [
  { href: "/", label: "Home" },
  { href: "/posts", label: "Posts" },
  { href: "/about", label: "About" },
];
---

<header class="border-b border-default sticky top-0 z-40 backdrop-blur bg-[rgb(var(--bg)/0.8)]">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-3 flex items-center justify-between gap-4">
    <a href="/" class="font-display font-bold tracking-tight text-lg hover:text-accent-600 transition">
      {siteConfig.title}
    </a>
    <nav class="flex items-center gap-4 text-sm">
      {nav.map((item) => (
        <a href={item.href} class="text-muted hover:text-[rgb(var(--fg))] transition">
          {item.label}
        </a>
      ))}
      <button
        id="theme-toggle"
        type="button"
        aria-label="Toggle theme"
        class="text-muted hover:text-[rgb(var(--fg))] text-base"
      >
        <span class="block dark:hidden">☾</span>
        <span class="hidden dark:block">☀</span>
      </button>
    </nav>
  </div>
</header>

<script is:inline>
  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    const isDark = document.documentElement.classList.toggle("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
  });
</script>
