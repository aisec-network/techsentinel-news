---
/**
 * News / Tracker cluster homepage. Newspaper-style — featured incident,
 * dense list of recent incidents in newspaper rows, sidebar "this week"
 * digest.
 */
import { siteConfig } from "@config/site";
import type { CollectionEntry } from "astro:content";

interface Props {
  posts: CollectionEntry<"posts">[];
}
const { posts } = Astro.props;
const featured = posts[0];
const secondary = posts.slice(1, 3);
const incidents = posts.slice(3, 13);
const weekStart = new Date();
weekStart.setDate(weekStart.getDate() - 7);
const thisWeek = posts.filter((p) => p.data.pubDate >= weekStart).slice(0, 6);

const dateline = new Date().toLocaleDateString("en-US", { weekday: "long", year: "numeric", month: "long", day: "numeric" });
---

<section class="max-w-6xl mx-auto px-4 sm:px-6 pt-8">
  <div class="border-y-2 border-[rgb(var(--fg))] py-3 flex items-baseline justify-between gap-4 flex-wrap">
    <h1 class="font-display font-black text-3xl sm:text-5xl tracking-tight leading-none">
      {siteConfig.title}
    </h1>
    <div class="font-mono text-[0.65rem] uppercase tracking-widest text-muted">{dateline} · Vol. {new Date().getFullYear() - 2024}</div>
  </div>
  <p class="text-muted text-sm mt-2">{siteConfig.tagline}</p>
</section>

<section class="max-w-6xl mx-auto px-4 sm:px-6 py-10 grid lg:grid-cols-12 gap-10">
  <div class="lg:col-span-8">
    {featured && (
      <a href={`/posts/${featured.slug}`} class="group block">
        {featured.data.heroImage && (
          <div class="aspect-[16/9] bg-muted overflow-hidden mb-5">
            <img src={featured.data.heroImage} alt={featured.data.heroAlt || featured.data.title} loading="eager" decoding="async" class="w-full h-full object-cover" />
          </div>
        )}
        {featured.data.category && (
          <div class="text-[0.65rem] uppercase tracking-[0.2em] text-red-700 font-semibold">{featured.data.category}</div>
        )}
        <h2 class="font-display font-black text-3xl sm:text-5xl leading-[1.05] mt-2 tracking-tight group-hover:text-accent-600 transition text-balance">
          {featured.data.title}
        </h2>
        <p class="text-base sm:text-lg leading-relaxed mt-4 max-w-2xl">{featured.data.description}</p>
        <div class="font-mono text-xs text-muted mt-3">
          {featured.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
        </div>
      </a>
    )}

    {secondary.length > 0 && (
      <div class="grid sm:grid-cols-2 gap-8 mt-10 pt-8 border-t border-default">
        {secondary.map((p) => (
          <a href={`/posts/${p.slug}`} class="group block">
            {p.data.category && (
              <div class="text-[0.6rem] uppercase tracking-[0.2em] text-red-700 font-semibold">{p.data.category}</div>
            )}
            <h3 class="font-display font-bold text-xl leading-snug mt-1 group-hover:text-accent-600 transition">{p.data.title}</h3>
            <p class="text-sm text-muted mt-2 line-clamp-3">{p.data.description}</p>
            <time class="font-mono text-xs text-muted mt-2 block">
              {p.data.pubDate.toLocaleDateString("en-US", { month: "short", day: "numeric" })}
            </time>
          </a>
        ))}
      </div>
    )}

    {incidents.length > 0 && (
      <section class="mt-12 pt-8 border-t border-default">
        <h2 class="font-display font-bold text-base uppercase tracking-wider mb-4">More incidents</h2>
        <ul class="divide-y divide-[rgb(var(--border))]">
          {incidents.map((p) => (
            <li class="py-3">
              <a href={`/posts/${p.slug}`} class="group flex items-baseline gap-4">
                <time class="font-mono text-xs text-muted shrink-0 tabular-nums w-24" datetime={p.data.pubDate.toISOString()}>
                  {p.data.pubDate.toLocaleDateString("en-US", { month: "short", day: "numeric" })}
                </time>
                <div class="flex-1 min-w-0">
                  <h3 class="font-display font-medium leading-snug group-hover:text-accent-600 transition">{p.data.title}</h3>
                  {p.data.category && (
                    <span class="text-[0.6rem] uppercase tracking-wider text-muted">{p.data.category}</span>
                  )}
                </div>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </div>

  <aside class="lg:col-span-4">
    <div class="sticky top-20 space-y-8">
      <section class="border-l-4 border-accent-600 pl-4">
        <div class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-accent-700 mb-1">This week</div>
        <h2 class="font-display font-bold text-xl">Latest digest</h2>
        {thisWeek.length === 0 ? (
          <p class="text-sm text-muted mt-2">Quiet week. Check back tomorrow.</p>
        ) : (
          <ul class="mt-3 space-y-3">
            {thisWeek.map((p) => (
              <li>
                <a href={`/posts/${p.slug}`} class="group block">
                  <h3 class="font-display font-semibold text-sm leading-snug group-hover:text-accent-600 transition line-clamp-2">{p.data.title}</h3>
                  <time class="font-mono text-xs text-muted">
                    {p.data.pubDate.toLocaleDateString("en-US", { weekday: "short", month: "short", day: "numeric" })}
                  </time>
                </a>
              </li>
            ))}
          </ul>
        )}
      </section>

      <section class="border border-default p-5 bg-surface">
        <div class="text-[0.65rem] uppercase tracking-[0.2em] text-muted">Subscribe</div>
        <p class="text-sm mt-2">Get the daily brief — incidents, breaches, advisories, the patches that matter.</p>
        <a href="/rss.xml" class="inline-block mt-3 text-sm font-semibold text-accent-700 hover:text-accent-800">RSS feed →</a>
      </section>
    </div>
  </aside>
</section>

{posts.length === 0 && (
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-12 text-muted">
    <p>Newsroom warming up. Check back tomorrow.</p>
  </section>
)}
