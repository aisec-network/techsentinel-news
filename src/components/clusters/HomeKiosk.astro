---
import { siteConfig } from "@config/site";
import type { CollectionEntry } from "astro:content";
import type { IdentityVoice } from "@config/identity";
import { identity } from "@config/identity";

interface Props {
  posts: CollectionEntry<"posts">[];
  voice?: IdentityVoice;
}
const { posts, voice = identity.voice } = Astro.props;
const featured = posts[0];
const stack = posts.slice(1, 7);
const tail = posts.slice(7, 19);
---

<section class="relative">
  <div aria-hidden="true" class="absolute inset-0 -z-10 bg-gradient-to-br from-accent-600/10 via-transparent to-accent-400/10"></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 pt-24 pb-20">
    <div class="font-mono text-xs uppercase tracking-[0.3em] text-accent-700 mb-6">{voice.site_motto}</div>
    <h1 class="font-display font-extrabold text-5xl sm:text-7xl lg:text-8xl tracking-tight leading-[0.9] max-w-5xl text-balance">
      {siteConfig.tagline}
    </h1>
    <p class="text-muted mt-8 max-w-3xl text-lg sm:text-xl leading-relaxed">{siteConfig.description}</p>
  </div>
</section>

{featured && (
  <section class="bg-[rgb(var(--surface-alt))]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-20 grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <div class="font-mono text-xs uppercase tracking-[0.2em] text-accent-700 mb-3">{voice.label_featured}</div>
        <h2 class="font-display font-bold text-3xl sm:text-5xl leading-[1.05] tracking-tight">
          <a href={`/posts/${featured.slug}`} class="hover:text-accent-600 transition">{featured.data.title}</a>
        </h2>
        <p class="text-muted mt-5 text-base sm:text-lg leading-relaxed">{featured.data.description}</p>
        <a href={`/posts/${featured.slug}`} class="inline-flex mt-6 items-center gap-2 text-accent-700 font-semibold hover:gap-3 transition-all">
          {voice.label_more} <span aria-hidden="true">→</span>
        </a>
      </div>
      {featured.data.heroImage && (
        <div class="aspect-[4/3] bg-muted overflow-hidden border border-default rounded-lg">
          <img src={featured.data.heroImage} alt={featured.data.heroAlt || featured.data.title} loading="eager" decoding="async" class="w-full h-full object-cover" />
        </div>
      )}
    </div>
  </section>
)}

{stack.length > 0 && (
  <section>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-20">
      <h2 class="font-display font-bold text-2xl uppercase tracking-wider mb-10">{voice.label_latest}</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-x-10 gap-y-14">
        {stack.map((p) => (
          <a href={`/posts/${p.slug}`} class="group block">
            {p.data.heroImage && (
              <div class="aspect-[3/2] bg-muted overflow-hidden mb-4 rounded-md border border-default">
                <img src={p.data.heroImage} alt={p.data.heroAlt || p.data.title} loading="lazy" decoding="async" class="w-full h-full object-cover group-hover:scale-[1.03] transition duration-500" />
              </div>
            )}
            {p.data.category && (
              <div class="font-mono text-[0.65rem] uppercase tracking-wider text-accent-700">{p.data.category}</div>
            )}
            <h3 class="font-display font-bold text-xl leading-snug mt-2 group-hover:text-accent-600 transition line-clamp-3">{p.data.title}</h3>
            <p class="text-sm text-muted mt-2 line-clamp-2">{p.data.description}</p>
            <time class="font-mono text-xs text-muted mt-3 block">
              {p.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
            </time>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

{tail.length > 0 && (
  <section class="bg-[rgb(var(--surface-alt))]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-20">
      <h2 class="font-display font-bold text-2xl uppercase tracking-wider mb-8">{voice.label_recent}</h2>
      <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-x-10 gap-y-5">
        {tail.map((p) => (
          <li>
            <a href={`/posts/${p.slug}`} class="group flex items-baseline gap-3 py-2 border-b border-default hover:border-accent-500 transition">
              <time class="font-mono text-xs text-muted shrink-0 tabular-nums w-16" datetime={p.data.pubDate.toISOString()}>
                {p.data.pubDate.toLocaleDateString("en-US", { month: "short", day: "numeric" })}
              </time>
              <span class="font-display font-medium leading-snug group-hover:text-accent-600 transition flex-1 line-clamp-1">{p.data.title}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
)}

{posts.length === 0 && (
  <section class="max-w-7xl mx-auto px-4 sm:px-6 py-20 text-muted">
    <p>{voice.cta_subscribe_desc}</p>
  </section>
)}
