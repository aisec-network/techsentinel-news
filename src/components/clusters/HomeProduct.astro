---
/**
 * Defensive / Tools cluster homepage. Product-page polish — featured tool
 * category, comparison-driven, "buyer's guide" emphasis.
 */
import { siteConfig } from "@config/site";
import type { CollectionEntry } from "astro:content";
import type { IdentityVoice } from "@config/identity";
import { identity } from "@config/identity";

interface Props {
  posts: CollectionEntry<"posts">[];
  voice?: IdentityVoice;
}
const { posts, voice = identity.voice } = Astro.props;
const featured = posts[0];
const guides = posts.slice(1, 4);
const recent = posts.slice(4, 12);
---

<section class="relative overflow-hidden">
  <div aria-hidden="true" class="absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-gradient-to-br from-accent-50/60 via-transparent to-accent-100/40 dark:from-accent-900/30 dark:to-accent-950/20"></div>
  </div>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 pt-20 pb-14 text-center">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs text-accent-700 bg-accent-100 dark:bg-accent-900/40 dark:text-accent-300 font-medium mb-6">
      <span class="size-1.5 rounded-full bg-accent-600 animate-pulse"></span>
      {siteConfig.title}
    </div>
    <h1 class="font-display font-extrabold text-4xl sm:text-6xl tracking-tight leading-[1.05] text-balance">
      {siteConfig.tagline}
    </h1>
    <p class="text-muted mt-5 text-base sm:text-lg leading-relaxed max-w-2xl mx-auto">
      {siteConfig.description}
    </p>
    <div class="mt-7 flex justify-center gap-3 flex-wrap">
      <a href="/posts" class="inline-flex px-5 py-2.5 rounded-md bg-accent-600 text-white font-medium hover:bg-accent-700 transition">
        {voice.label_more}
      </a>
      <a href="/about" class="inline-flex px-5 py-2.5 rounded-md border border-default font-medium hover:border-accent-500 transition">
        {voice.nav_about}
      </a>
    </div>
  </div>
</section>

{featured && (
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
    <a href={`/posts/${featured.slug}`} class="block rounded-2xl border border-default bg-surface overflow-hidden group hover:shadow-xl hover:border-accent-500 transition">
      <div class="grid md:grid-cols-2 items-center">
        {featured.data.heroImage && (
          <div class="aspect-[4/3] bg-muted overflow-hidden">
            <img src={featured.data.heroImage} alt={featured.data.heroAlt || featured.data.title} loading="eager" decoding="async" class="w-full h-full object-cover group-hover:scale-[1.02] transition duration-500" />
          </div>
        )}
        <div class={`p-8 sm:p-10 ${featured.data.heroImage ? "" : "md:col-span-2"}`}>
          <span class="text-xs uppercase tracking-wider text-accent-700 font-bold">{voice.label_featured}</span>
          <h2 class="font-display font-extrabold text-2xl sm:text-3xl leading-tight tracking-tight mt-2 group-hover:text-accent-600 transition">
            {featured.data.title}
          </h2>
          <p class="text-muted mt-3 leading-relaxed">{featured.data.description}</p>
          <div class="mt-5 inline-flex items-center gap-1 text-accent-700 font-semibold group-hover:gap-2 transition-all">
            {voice.label_more} <span aria-hidden="true">→</span>
          </div>
        </div>
      </div>
    </a>
  </section>
)}

{guides.length > 0 && (
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-12">
    <h2 class="text-xs uppercase tracking-wider text-muted font-semibold mb-5">{voice.label_featured}</h2>
    <div class="grid md:grid-cols-3 gap-5">
      {guides.map((p) => (
        <a href={`/posts/${p.slug}`} class="group block rounded-xl border border-default bg-surface p-6 hover:border-accent-500 hover:shadow-lg transition">
          {p.data.category && (
            <div class="text-[0.65rem] uppercase tracking-wider text-accent-700 font-bold">{p.data.category}</div>
          )}
          <h3 class="font-display font-bold text-lg leading-snug mt-2 group-hover:text-accent-600 transition line-clamp-3">{p.data.title}</h3>
          <p class="text-sm text-muted mt-2 line-clamp-3">{p.data.description}</p>
          <div class="mt-4 text-sm font-semibold text-accent-700 inline-flex items-center gap-1 group-hover:gap-2 transition-all">
            Compare <span aria-hidden="true">→</span>
          </div>
        </a>
      ))}
    </div>
  </section>
)}

{recent.length > 0 && (
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-16">
    <h2 class="text-xs uppercase tracking-wider text-muted font-semibold mb-4">{voice.label_recent}</h2>
    <ul class="divide-y divide-[rgb(var(--border))] rounded-lg border border-default bg-surface">
      {recent.map((p) => (
        <li>
          <a href={`/posts/${p.slug}`} class="flex items-baseline gap-4 px-5 py-3 hover:bg-muted transition group">
            <h3 class="font-medium group-hover:text-accent-600 transition flex-1 truncate">{p.data.title}</h3>
            <time class="font-mono text-xs text-muted shrink-0 tabular-nums" datetime={p.data.pubDate.toISOString()}>
              {p.data.pubDate.toLocaleDateString("en-US", { month: "short", day: "numeric" })}
            </time>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}

{posts.length === 0 && (
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-12 text-muted text-center">
    <p>Reviews queue is being populated.</p>
  </section>
)}
