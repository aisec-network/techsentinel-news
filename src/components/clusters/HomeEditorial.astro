---
/**
 * Offensive-sec cluster homepage. Editorial — featured technique, recent
 * writeups in a typed list, "tools we cover" strip, RSS-style latest.
 */
import { siteConfig } from "@config/site";
import type { CollectionEntry } from "astro:content";

interface Props {
  posts: CollectionEntry<"posts">[];
}
const { posts } = Astro.props;
const featured = posts[0];
const next = posts.slice(1, 4);
const recent = posts.slice(4, 14);
---

<section class="border-b border-default">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 pt-12 pb-10">
    <div class="font-mono text-xs uppercase tracking-[0.2em] text-muted mb-4">
      // {siteConfig.title}
    </div>
    <h1 class="font-display font-bold text-4xl sm:text-6xl tracking-tight leading-[0.95] max-w-4xl text-balance">
      {siteConfig.tagline}
    </h1>
    <p class="text-muted mt-5 max-w-2xl text-base sm:text-lg">{siteConfig.description}</p>
  </div>
</section>

{featured && (
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-12 border-b border-default">
    <a href={`/posts/${featured.slug}`} class="grid md:grid-cols-12 gap-8 group">
      {featured.data.heroImage && (
        <div class="md:col-span-7 aspect-[21/9] md:aspect-[4/3] bg-muted overflow-hidden border border-default">
          <img src={featured.data.heroImage} alt={featured.data.heroAlt || featured.data.title} loading="eager" decoding="async" class="w-full h-full object-cover group-hover:scale-[1.02] transition duration-700" />
        </div>
      )}
      <div class={featured.data.heroImage ? "md:col-span-5" : "md:col-span-12"}>
        <span class="font-mono text-xs uppercase tracking-wider text-accent-700">// Latest writeup</span>
        <h2 class="font-display font-bold text-2xl sm:text-4xl mt-3 leading-tight tracking-tight group-hover:text-accent-600 transition">
          {featured.data.title}
        </h2>
        <p class="text-muted mt-3 text-base leading-relaxed">{featured.data.description}</p>
        <div class="mt-4 font-mono text-xs text-muted">
          {featured.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
          {featured.data.category && (<span class="ml-3 text-accent-700">[{featured.data.category}]</span>)}
        </div>
      </div>
    </a>
  </section>
)}

{next.length > 0 && (
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-12 border-b border-default">
    <div class="grid md:grid-cols-3 gap-8">
      {next.map((p) => (
        <a href={`/posts/${p.slug}`} class="group block">
          {p.data.heroImage && (
            <div class="aspect-[16/9] overflow-hidden bg-muted border border-default mb-4">
              <img src={p.data.heroImage} alt={p.data.heroAlt || p.data.title} loading="lazy" decoding="async" class="w-full h-full object-cover group-hover:scale-[1.03] transition duration-500" />
            </div>
          )}
          {p.data.category && (
            <div class="font-mono text-[0.65rem] uppercase tracking-wider text-accent-700">{p.data.category}</div>
          )}
          <h3 class="font-display font-semibold text-lg leading-snug mt-1 group-hover:text-accent-600 transition line-clamp-3">{p.data.title}</h3>
          <p class="text-sm text-muted mt-1 line-clamp-2">{p.data.description}</p>
          <time class="font-mono text-xs text-muted mt-2 block" datetime={p.data.pubDate.toISOString()}>
            {p.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
          </time>
        </a>
      ))}
    </div>
  </section>
)}

{recent.length > 0 && (
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <h2 class="font-mono text-xs uppercase tracking-[0.2em] text-muted mb-6">// Recent</h2>
    <ul class="divide-y divide-[rgb(var(--border))]">
      {recent.map((p) => (
        <li class="py-4">
          <a href={`/posts/${p.slug}`} class="group grid grid-cols-12 gap-4">
            <time class="col-span-12 sm:col-span-2 font-mono text-xs text-muted pt-1" datetime={p.data.pubDate.toISOString()}>
              {p.data.pubDate.toLocaleDateString("en-US", { year: "2-digit", month: "2-digit", day: "2-digit" })}
            </time>
            <div class="col-span-12 sm:col-span-10">
              <h3 class="font-display font-medium leading-snug group-hover:text-accent-600 transition">{p.data.title}</h3>
              <p class="text-sm text-muted mt-1 line-clamp-1">{p.data.description}</p>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}

{posts.length === 0 && (
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-12 text-muted">
    <p class="font-mono text-sm">// no writeups yet — first publication imminent.</p>
  </section>
)}
