---
/**
 * Engineering / MLOps cluster homepage. Dashboardy — featured topic with
 * stats strip, three-up grid of sub-topics, recent updates table.
 */
import { siteConfig } from "@config/site";
import type { CollectionEntry } from "astro:content";

interface Props {
  posts: CollectionEntry<"posts">[];
}
const { posts } = Astro.props;
const featured = posts[0];
const triplet = posts.slice(1, 4);
const recent = posts.slice(4, 12);

// Pull a few quick stats from the post collection for the hero strip.
const totalPosts = posts.length;
const categories = new Set(posts.map((p) => p.data.category).filter(Boolean));
const lastUpdated = posts[0]?.data.pubDate;
---

<section class="relative">
  <div aria-hidden="true" class="absolute inset-0 grid-bg opacity-40 pointer-events-none"></div>
  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 pt-16 pb-12">
    <div class="max-w-3xl">
      <span class="inline-block text-xs uppercase tracking-wider text-accent-700 font-semibold">{siteConfig.title}</span>
      <h1 class="font-display font-extrabold text-4xl sm:text-6xl tracking-tight leading-[1.05] mt-3 text-balance">
        {siteConfig.tagline}
      </h1>
      <p class="text-muted mt-5 text-base sm:text-lg leading-relaxed">{siteConfig.description}</p>
    </div>

    <div class="mt-10 grid grid-cols-2 sm:grid-cols-4 gap-px bg-[rgb(var(--border))] border border-default rounded-lg overflow-hidden text-sm">
      <div class="bg-surface px-4 py-3">
        <div class="text-xs text-muted uppercase tracking-wider">Posts</div>
        <div class="font-display text-2xl font-bold tabular-nums mt-0.5">{totalPosts}</div>
      </div>
      <div class="bg-surface px-4 py-3">
        <div class="text-xs text-muted uppercase tracking-wider">Topics</div>
        <div class="font-display text-2xl font-bold tabular-nums mt-0.5">{categories.size}</div>
      </div>
      <div class="bg-surface px-4 py-3">
        <div class="text-xs text-muted uppercase tracking-wider">Updated</div>
        <div class="font-display text-base font-semibold mt-0.5">
          {lastUpdated ? lastUpdated.toLocaleDateString("en-US", { month: "short", day: "numeric" }) : "—"}
        </div>
      </div>
      <div class="bg-surface px-4 py-3 flex items-center">
        <a href="/rss.xml" class="font-display text-sm font-semibold text-accent-700 hover:text-accent-800 transition">Subscribe via RSS →</a>
      </div>
    </div>
  </div>
</section>

{featured && (
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <a href={`/posts/${featured.slug}`} class="block rounded-xl border border-default bg-surface overflow-hidden group hover:border-accent-500 transition">
      <div class="grid md:grid-cols-12">
        {featured.data.heroImage && (
          <div class="md:col-span-6 aspect-[16/9] md:aspect-auto bg-muted overflow-hidden">
            <img src={featured.data.heroImage} alt={featured.data.heroAlt || featured.data.title} loading="eager" decoding="async" class="w-full h-full object-cover group-hover:scale-[1.02] transition duration-500" />
          </div>
        )}
        <div class={`p-6 sm:p-8 ${featured.data.heroImage ? "md:col-span-6" : "md:col-span-12"}`}>
          <span class="text-xs uppercase tracking-wider text-accent-700 font-semibold">Featured</span>
          <h2 class="font-display font-extrabold text-2xl sm:text-3xl leading-tight tracking-tight mt-2 group-hover:text-accent-600 transition">
            {featured.data.title}
          </h2>
          <p class="text-muted mt-3 leading-relaxed">{featured.data.description}</p>
          <div class="text-xs text-muted mt-4">
            {featured.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
          </div>
        </div>
      </div>
    </a>
  </section>
)}

{triplet.length > 0 && (
  <section class="max-w-6xl mx-auto px-4 sm:px-6 pb-12">
    <div class="grid md:grid-cols-3 gap-5">
      {triplet.map((p) => (
        <a href={`/posts/${p.slug}`} class="group block rounded-lg border border-default bg-surface p-5 hover:border-accent-500 transition">
          {p.data.category && (
            <div class="text-[0.65rem] uppercase tracking-wider text-accent-700 font-semibold">{p.data.category}</div>
          )}
          <h3 class="font-display font-bold text-lg leading-snug mt-1 group-hover:text-accent-600 transition line-clamp-3">{p.data.title}</h3>
          <p class="text-sm text-muted mt-2 line-clamp-3">{p.data.description}</p>
        </a>
      ))}
    </div>
  </section>
)}

{recent.length > 0 && (
  <section class="max-w-6xl mx-auto px-4 sm:px-6 pb-16">
    <h2 class="text-xs uppercase tracking-wider text-muted font-semibold mb-4">Recent updates</h2>
    <div class="rounded-lg border border-default bg-surface divide-y divide-[rgb(var(--border))]">
      {recent.map((p) => (
        <a href={`/posts/${p.slug}`} class="flex items-baseline gap-4 px-5 py-3 hover:bg-muted transition group">
          <time class="font-mono text-xs text-muted tabular-nums w-20 shrink-0" datetime={p.data.pubDate.toISOString()}>
            {p.data.pubDate.toLocaleDateString("en-US", { month: "short", day: "numeric" })}
          </time>
          <span class="font-medium group-hover:text-accent-600 transition flex-1 truncate">{p.data.title}</span>
          {p.data.category && (
            <span class="text-[0.65rem] uppercase tracking-wider text-muted hidden sm:inline">{p.data.category}</span>
          )}
        </a>
      ))}
    </div>
  </section>
)}

{posts.length === 0 && (
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-12 text-muted">
    <p>Pipeline warming up. First posts shipping shortly.</p>
  </section>
)}
