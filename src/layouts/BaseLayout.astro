---
import "@/styles/globals.css";
import "@/styles/brand.css";
import Head from "@components/Head.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import { siteConfig } from "@config/site";
import { hueToAccentRamp } from "@config/clusters";
import { identity } from "@config/identity";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  type?: "website" | "article";
  publishedTime?: Date;
  modifiedTime?: Date;
  author?: string;
  tags?: string[];
  noindex?: boolean;
  fullBleed?: boolean;
}

const props = Astro.props;
const cluster = siteConfig.brand.cluster;
const ramp = hueToAccentRamp(identity.palette.hue);

const accentVars = Object.entries(ramp)
  .map(([stop, rgb]) => `--accent-${stop}:${rgb};`)
  .join("");
const inlineStyle = `--accent-hue:${identity.palette.hue};${accentVars}`;
---

<!doctype html>
<html lang={siteConfig.language}>
  <head>
    <Head {...props} />
  </head>
  <body
    class={`min-h-screen flex flex-col density-${identity.layout.density} layout-${identity.layout.id} font-${identity.palette.neutral_family}`}
    data-cluster={cluster}
    data-layout={identity.layout.id}
    data-density={identity.layout.density}
    style={inlineStyle}
  >
    <Header />
    {props.fullBleed ? (
      <slot />
    ) : (
      <main class="flex-1 max-w-5xl mx-auto w-full px-4 sm:px-6 py-8">
        <slot />
      </main>
    )}
    <Footer />
  </body>
</html>
