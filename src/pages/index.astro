---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import NewsletterSignup from "@components/NewsletterSignup.astro";
import HomeEditorial from "@components/clusters/HomeEditorial.astro";
import HomeDashboard from "@components/clusters/HomeDashboard.astro";
import HomeNewspaper from "@components/clusters/HomeNewspaper.astro";
import HomeCivic from "@components/clusters/HomeCivic.astro";
import HomeProduct from "@components/clusters/HomeProduct.astro";
import HomeKiosk from "@components/clusters/HomeKiosk.astro";
import { siteConfig } from "@config/site";
import { identity } from "@config/identity";

const posts = (await getCollection("posts", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const layoutId = identity.layout.id;
const voice = identity.voice;
---

<BaseLayout title={siteConfig.title} description={siteConfig.description} fullBleed>
  {layoutId === "magazine"  && <HomeEditorial  posts={posts} voice={voice} />}
  {layoutId === "dashboard" && <HomeDashboard  posts={posts} voice={voice} />}
  {layoutId === "feed"      && <HomeNewspaper  posts={posts} voice={voice} />}
  {layoutId === "longform"  && <HomeCivic      posts={posts} voice={voice} />}
  {layoutId === "directory" && <HomeProduct    posts={posts} voice={voice} />}
  {layoutId === "kiosk"     && <HomeKiosk      posts={posts} voice={voice} />}

  <div class="max-w-3xl mx-auto px-4 sm:px-6 pb-12">
    <NewsletterSignup />
  </div>
</BaseLayout>
