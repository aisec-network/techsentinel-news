---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import NewsletterSignup from "@components/NewsletterSignup.astro";
import HomeEditorial from "@components/clusters/HomeEditorial.astro";
import HomeDashboard from "@components/clusters/HomeDashboard.astro";
import HomeNewspaper from "@components/clusters/HomeNewspaper.astro";
import HomeCivic from "@components/clusters/HomeCivic.astro";
import HomeProduct from "@components/clusters/HomeProduct.astro";
import { siteConfig } from "@config/site";
import { clusters } from "@config/clusters";

const posts = (await getCollection("posts", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const layout = clusters[siteConfig.brand.cluster].homepageLayout;
---

<BaseLayout title={siteConfig.title} description={siteConfig.description} fullBleed>
  {layout === "editorial"  && <HomeEditorial  posts={posts} />}
  {layout === "dashboard"  && <HomeDashboard  posts={posts} />}
  {layout === "newspaper"  && <HomeNewspaper  posts={posts} />}
  {layout === "civic"      && <HomeCivic      posts={posts} />}
  {layout === "product"    && <HomeProduct    posts={posts} />}

  <div class="max-w-3xl mx-auto px-4 sm:px-6 pb-12">
    <NewsletterSignup />
  </div>
</BaseLayout>
