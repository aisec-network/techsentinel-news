---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import { siteConfig } from "@config/site";
import personasData from "@/data/personas.json";

interface Persona {
  id: string;
  name: string;
  cluster?: string;
  bio_short?: string;
  bio_long?: string;
  voice?: string[];
  sites?: string[];
  avatar_prompt?: string;
}

interface PersonasFile {
  personas: Persona[];
}

function slugify(s: string): string {
  return s.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");
}

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  const byAuthor = new Map<string, { name: string; posts: typeof posts }>();
  for (const p of posts) {
    const name = p.data.author || "Editorial";
    const key = name.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");
    if (!byAuthor.has(key)) byAuthor.set(key, { name, posts: [] });
    byAuthor.get(key)!.posts.push(p);
  }
  return [...byAuthor.entries()].map(([key, { name, posts: authorPosts }]) => ({
    params: { author: key },
    props: {
      authorSlug: key,
      authorName: name,
      posts: authorPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { authorSlug, authorName, posts } = Astro.props as {
  authorSlug: string;
  authorName: string;
  posts: Awaited<ReturnType<typeof getCollection<"posts">>>;
};

const personas = (personasData as PersonasFile).personas || [];
const persona = personas.find(
  (p) => slugify(p.name) === authorSlug || p.id === authorSlug
);

const avatarUrl = persona?.avatar_prompt
  ? `https://aisec-imagegen.th3gptoperator.workers.dev/?prompt=${encodeURIComponent(
      persona.avatar_prompt + ", professional headshot, square"
    )}&aspect=square`
  : null;

const sameAs = persona?.sites
  ? persona.sites
      .filter((s) => s.replace(/-([^-]+)$/, ".$1") !== siteConfig.domain)
      .map((s) => `https://${s.replace(/-([^-]+)$/, ".$1")}/authors/${authorSlug}`)
  : [];

const personSchema = persona
  ? {
      "@context": "https://schema.org",
      "@type": "Person",
      name: persona.name,
      description: persona.bio_short || "",
      url: `${siteConfig.url}/authors/${authorSlug}`,
      ...(persona.voice && { knowsAbout: persona.voice }),
      ...(sameAs.length && { sameAs }),
    }
  : {
      "@context": "https://schema.org",
      "@type": "Person",
      name: authorName,
      url: `${siteConfig.url}/authors/${authorSlug}`,
    };

const pageTitle = persona?.name || authorName;
const pageDescription = persona?.bio_short || `Posts by ${authorName}.`;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)}></script>

  <article class="max-w-3xl mx-auto">
    <header class="mb-12">
      <p class="text-xs uppercase tracking-wider text-accent-700 font-mono mb-2">Author</p>
      <div class="flex items-start gap-6 flex-col sm:flex-row">
        {avatarUrl && (
          <img
            src={avatarUrl}
            alt={pageTitle}
            width="120"
            height="120"
            loading="eager"
            class="rounded-full object-cover w-24 h-24 sm:w-30 sm:h-30 flex-shrink-0 border border-default"
          />
        )}
        <div class="flex-1 min-w-0">
          <h1 class="font-display font-bold text-3xl sm:text-4xl tracking-tight mb-2">{pageTitle}</h1>
          {persona?.bio_short && <p class="text-lg text-muted leading-snug">{persona.bio_short}</p>}
          {persona?.voice && persona.voice.length > 0 && (
            <p class="mt-3 text-xs text-muted font-mono">
              {persona.voice.join(" · ")}
            </p>
          )}
        </div>
      </div>
      {persona?.bio_long && (
        <p class="mt-6 text-base leading-relaxed">{persona.bio_long}</p>
      )}
    </header>

    {sameAs.length > 0 && (
      <section class="mb-12">
        <h2 class="text-xs uppercase tracking-wider text-muted font-mono mb-3">Also writes for</h2>
        <ul class="text-sm flex flex-wrap gap-2">
          {persona!.sites!
            .map((s) => s.replace(/-([^-]+)$/, ".$1"))
            .filter((dom) => dom !== siteConfig.domain)
            .map((dom) => (
              <li>
                <a
                  href={`https://${dom}/authors/${authorSlug}`}
                  rel="noopener"
                  class="inline-block px-3 py-1.5 rounded border border-default text-muted hover:text-accent-700 hover:border-accent-400 transition"
                >
                  {dom}
                </a>
              </li>
            ))}
        </ul>
      </section>
    )}

    <section>
      <h2 class="font-display font-bold text-2xl tracking-tight mb-5 pb-2 border-b border-default">
        Posts {posts.length > 0 && <span class="text-base text-muted font-mono ml-2">({posts.length})</span>}
      </h2>
      {posts.length === 0 ? (
        <p class="text-muted">No posts yet.</p>
      ) : (
        <ul class="divide-y divide-[rgb(var(--border))]">
          {posts.map((p) => (
            <li class="py-5">
              <a href={`/posts/${p.slug}`} class="group block">
                {p.data.category && (
                  <div class="text-[0.65rem] uppercase tracking-wider text-accent-700 font-mono mb-1">
                    {p.data.category}
                  </div>
                )}
                <h3 class="font-display font-semibold text-lg leading-snug group-hover:text-accent-600 transition">
                  {p.data.title}
                </h3>
                <p class="text-sm text-muted mt-1 line-clamp-2">{p.data.description}</p>
                <time class="text-xs text-muted mt-2 block font-mono" datetime={p.data.pubDate.toISOString()}>
                  {p.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
                </time>
              </a>
            </li>
          ))}
        </ul>
      )}
    </section>
  </article>
</BaseLayout>
