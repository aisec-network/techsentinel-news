---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";

const posts = (await getCollection("posts", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="All posts" description="Archive of all posts.">
  <h1 class="font-display font-bold text-3xl mb-6">All posts</h1>
  <ul class="divide-y divide-[rgb(var(--border))]">
    {posts.map((p) => (
      <li class="py-4">
        <a href={`/posts/${p.slug}`} class="group block">
          <h2 class="font-medium group-hover:text-accent-600 transition">{p.data.title}</h2>
          <p class="text-sm text-muted mt-1">{p.data.description}</p>
          <time class="text-xs text-muted mt-1 block" datetime={p.data.pubDate.toISOString()}>
            {p.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
          </time>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>
